<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="TbspRpgStudio.Views.SourceEditModifyView"
             xmlns:viewModels="clr-namespace:TbspRpgStudio.ViewModels"
             xmlns:mdxaml="https://github.com/whistyun/Markdown.Avalonia"
             x:DataType="viewModels:SourceEditModifyViewModel">
    <Grid RowDefinitions="10*, 1*">
        <StackPanel Grid.Row="0" Margin="0, 40, 0, 0">
            <TextBlock Text="{Binding Source.Key}" FontSize="20"/>
            <Separator></Separator>
            <TextBox Name="TextBox" TextWrapping="Wrap" Height="100" Margin="0,20"
                     Text="{Binding  Source.Text}" />
            <StackPanel Margin="0, 40, 0, 0">
                <TextBlock Text="Associated Scripts" FontSize="20" />
                <Separator></Separator>
            </StackPanel>
            <StackPanel Margin="0, 40, 0, 0">
                <TextBlock Text="Preview" FontSize="20" />
                <Separator></Separator>
                <Border Name="PreviewBorder" BorderThickness="1" Padding="10" Margin="0, 20">
                    <mdxaml:MarkdownScrollViewer Height="100" 
                                                 Markdown="{Binding #TextBox.Text}" />
                </Border>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Command="{Binding CancelEdit}">Cancel</Button>
            <Button Name="SaveButton" Margin="0, 0, 15, 0" Command="{Binding SaveCommand}">Save</Button>
        </StackPanel>
    </Grid>
</UserControl>
